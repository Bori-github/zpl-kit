{
  "name": "zpl-kit",
  "version": "0.0.0",
  "private": true,
  "author": "boriguri <qhflrnfl4324@gmail.com>",
  "license": "MIT",
  "homepage": "https://boriguri.github.io/zpl-kit/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bori-github/zpl-kit.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "pnpm --filter './apps/*' dev",
    "demo:web": "pnpm --filter './demos/web' dev",
    "demo:electron": "pnpm --filter './demos/electron' dev",
    "build": "pnpm --filter @zpl-kit/zpl-core build && pnpm --filter './apps/*' --filter '!@zpl-kit/zpl-core' build && pnpm --filter './demos/*' build",
    "test": "vitest",
    "type-check": "pnpm -r type-check",
    "lint": "oxlint --deny-warnings",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "docs:preview": "pnpm --filter docs preview"
  },
  "devDependencies": {
    "rolldown": "^1.0.0-beta.51",
    "oxlint": "^0.15.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
